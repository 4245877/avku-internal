# Зависимости (удаляем node_modules отовсюду)
node_modules/
**/node_modules/

# Папки сборки (директории билда фронтенда)
dist/
**/dist/
.vite/
**/.vite/

# Логи и кэш
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.cache/

# Локальные переменные окружения (конфиденциальные данные)
.env
.env.local
.env.*.local

# Системные файлы
.DS_Store
Thumbs.db
# Generated certificates and personal photos
storage/certificates/*.sqlite
storage/certificates/*.sqlite-*
storage/certificates/photos/*
!storage/certificates/photos/.gitkeep
storage/certificates/generated/*
!storage/certificates/generated/.gitkeep
# Warehouse database (regenerated/seeded on startup)
storage/warehouse/*.sqlite
storage/warehouse/*.sqlite-*
# Logistics database (regenerated/seeded on startup)
storage/logistics/*.sqlite
storage/logistics/*.sqlite-*
storage/backups/



# Local tool / pnpm cache
.tools/pnpm-store/
.tools/**/pnpm-store/

# Local tools and caches
.tools/

# Vite check/build artifacts
apps/web/.vite-cert-check/
apps/web/vite-*.log
apps/web/certificates-screenshot.png